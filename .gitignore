# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

!.env.example

# replay cache — regenerable via fetchAndCacheMatch(), EXCEPT the two
# matches independent-verify.ts and the /verify dashboard page depend on:
# those are committed on purpose, so cloning the repo is enough to
# independently re-verify without live TxLINE credentials.
/data/replay-cache/*
!/data/replay-cache/.gitkeep
!/data/replay-cache/18222446.json
!/data/replay-cache/18213979.json
!/data/replay-cache/18237038.json

# agent logs
/logs/

# demo materials — never committed
DEMO_SCRIPT.md
*.mp4
*.mov
*.webm
*.mkv
