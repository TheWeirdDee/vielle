# VEILLE Environment Variables
# Copy to .env — never commit this file

# TxLINE (mainnet, Service Level 12 — free, real-time World Cup)
TXLINE_API_TOKEN=              # from scripts/activate.ts — long-lived
TXLINE_GUEST_JWT=              # seed value — auto-renewed at runtime on 401
TXLINE_API_BASE=https://txline.txodds.com/api
TXLINE_API_ORIGIN=https://txline.txodds.com

# Solana (mainnet — activation + on-chain memo writes)
SOLANA_WALLET_PRIVATE_KEY=     # base58 encoded — NEVER commit
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Supabase
NEXT_PUBLIC_SUPABASE_URL=      # Settings → API → Project URL
SUPABASE_SERVICE_KEY=          # Settings → API → service_role key

# Signal (set after running scripts/register-signal.ts)
SIGNAL_REGISTRY_ID=            # UUID from veille_signal_registry table
